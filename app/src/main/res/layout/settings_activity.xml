<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1F2937"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Header row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/settings_title"
                android:textColor="#F9FAFB"
                android:textSize="20sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btn_settings_close"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/btn_close"
                android:backgroundTint="#374151"
                android:textColor="#D1D5DB" />
        </LinearLayout>

        <!-- Section: Speicherort -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_section_storage"
            android:textColor="#60A5FA"
            android:textSize="12sp"
            android:textAllCaps="true"
            android:letterSpacing="0.1"
            android:layout_marginBottom="12dp" />

        <!-- Folder card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#111827"
            android:padding="16dp"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/settings_folder_label"
                android:textColor="#9CA3AF"
                android:textSize="12sp"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/txt_folder_path"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#F3F4F6"
                android:textSize="14sp"
                android:layout_marginBottom="12dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btn_choose_folder"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:text="@string/settings_folder_choose"
                    android:backgroundTint="#3B82F6"
                    android:textColor="#FFFFFF" />

                <Button
                    android:id="@+id/btn_reset_folder"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_folder_reset_btn"
                    android:backgroundTint="#374151"
                    android:textColor="#9CA3AF" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/settings_folder_hint"
                android:textColor="#6B7280"
                android:textSize="12sp"
                android:layout_marginTop="8dp" />
        </LinearLayout>

        <!-- Section: E-Mail -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_section_email"
            android:textColor="#60A5FA"
            android:textSize="12sp"
            android:textAllCaps="true"
            android:letterSpacing="0.1"
            android:layout_marginBottom="12dp" />

        <!-- E-Mail card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#111827"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/settings_email_label"
                android:textColor="#9CA3AF"
                android:textSize="12sp"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/edit_email"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/settings_email_hint"
                android:inputType="textEmailAddress"
                android:textColor="#F3F4F6"
                android:textColorHint="#6B7280"
                android:background="#1F2937"
                android:padding="10dp"
                android:textSize="14sp"
                android:layout_marginBottom="12dp" />

            <Button
                android:id="@+id/btn_save_email"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/settings_email_save"
                android:backgroundTint="#3B82F6"
                android:textColor="#FFFFFF" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/settings_email_hint_desc"
                android:textColor="#6B7280"
                android:textSize="12sp"
                android:layout_marginTop="8dp" />
        </LinearLayout>

    </LinearLayout>

</ScrollView>
