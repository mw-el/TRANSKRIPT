<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cl_bg"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/space_5">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="@dimen/space_4"
            android:layout_marginBottom="@dimen/space_5">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/settings_title"
                android:textSize="@dimen/text_title"
                android:fontFamily="@font/poppins_semibold"
                android:textStyle="bold"
                android:textColor="@color/cl_ink"/>

            <ImageButton
                android:id="@+id/btn_settings_close"
                android:layout_width="@dimen/btn_icon_size"
                android:layout_height="@dimen/btn_icon_size"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                android:tint="@color/cl_ink_soft"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/btn_close"
                android:padding="10dp"/>
        </LinearLayout>

        <!-- Section: Sprache -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_section_language_label"
            style="@style/SectionLabelStyle"
            android:textAllCaps="true"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="@dimen/space_5"
            android:layout_marginBottom="@dimen/space_4">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/settings_language_label"
                android:textColor="@color/cl_ink"
                android:fontFamily="@font/inter_medium"
                android:textSize="@dimen/text_normal"
                android:layout_marginBottom="@dimen/space_2"/>

            <Spinner
                android:id="@+id/spinner_language"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/space_3"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/settings_language_desc"
                android:textColor="@color/cl_ink_soft"
                android:fontFamily="@font/inter_regular"
                android:textSize="@dimen/text_small"/>
        </LinearLayout>

        <!-- Section: Aufnahme -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="AUFNAHME"
            style="@style/SectionLabelStyle"
            android:textAllCaps="true"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="@dimen/space_5"
            android:layout_marginBottom="@dimen/space_4">

            <!-- Auto-record -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginEnd="@dimen/space_4">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/setting_auto_record"
                        android:textSize="@dimen/text_normal"
                        android:fontFamily="@font/inter_medium"
                        android:textColor="@color/cl_ink"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/setting_auto_record_desc"
                        android:textSize="@dimen/text_small"
                        android:fontFamily="@font/inter_regular"
                        android:textColor="@color/cl_ink_soft"
                        android:layout_marginTop="2dp"/>
                </LinearLayout>

                <Switch
                    android:id="@+id/switch_auto_record"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/cl_border"
                android:layout_marginTop="@dimen/space_4"
                android:layout_marginBottom="@dimen/space_4"/>

            <!-- Select transcription -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginEnd="@dimen/space_4">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/setting_select_transcription"
                        android:textSize="@dimen/text_normal"
                        android:fontFamily="@font/inter_medium"
                        android:textColor="@color/cl_ink"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/setting_select_transcription_desc"
                        android:textSize="@dimen/text_small"
                        android:fontFamily="@font/inter_regular"
                        android:textColor="@color/cl_ink_soft"
                        android:layout_marginTop="2dp"/>
                </LinearLayout>

                <Switch
                    android:id="@+id/switch_select_transcription"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/cl_border"
                android:layout_marginTop="@dimen/space_4"
                android:layout_marginBottom="@dimen/space_4"/>

            <!-- Pause audio -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginEnd="@dimen/space_4">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/setting_pause_audio"
                        android:textSize="@dimen/text_normal"
                        android:fontFamily="@font/inter_medium"
                        android:textColor="@color/cl_ink"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/setting_pause_audio_desc"
                        android:textSize="@dimen/text_small"
                        android:fontFamily="@font/inter_regular"
                        android:textColor="@color/cl_ink_soft"
                        android:layout_marginTop="2dp"/>
                </LinearLayout>

                <Switch
                    android:id="@+id/switch_pause_audio"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Section: Speicher -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_section_storage_label"
            style="@style/SectionLabelStyle"
            android:textAllCaps="true"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="@dimen/space_5"
            android:layout_marginBottom="@dimen/space_4">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/settings_folder_label"
                android:textColor="@color/cl_ink"
                android:fontFamily="@font/inter_medium"
                android:textSize="@dimen/text_normal"
                android:layout_marginBottom="@dimen/space_2"/>

            <TextView
                android:id="@+id/txt_folder_path"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/cl_ink_soft"
                android:fontFamily="@font/inter_regular"
                android:textSize="@dimen/text_small"
                android:layout_marginBottom="@dimen/space_3"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/settings_folder_hint"
                android:textColor="@color/cl_ink_soft"
                android:fontFamily="@font/inter_regular"
                android:textSize="@dimen/text_small"
                android:layout_marginBottom="@dimen/space_2"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/settings_folder_default_hint"
                android:textColor="@color/cl_accent"
                android:fontFamily="@font/inter_regular"
                android:textSize="@dimen/text_small"
                android:layout_marginBottom="@dimen/space_4"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btn_choose_folder"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="@dimen/space_2"
                    android:text="@string/settings_folder_choose"
                    style="@style/ButtonStyle"/>

                <Button
                    android:id="@+id/btn_reset_folder"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_folder_reset_btn"
                    style="@style/SecondaryButtonStyle"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Section: E-Mail -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_section_email_label"
            style="@style/SectionLabelStyle"
            android:textAllCaps="true"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="@dimen/space_5"
            android:layout_marginBottom="@dimen/space_4">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/settings_email_hint_desc"
                android:textColor="@color/cl_ink_soft"
                android:fontFamily="@font/inter_regular"
                android:textSize="@dimen/text_small"
                android:layout_marginBottom="@dimen/space_3"/>

            <EditText
                android:id="@+id/edit_email"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/settings_email_hint"
                android:inputType="textEmailAddress"
                android:textColor="@color/cl_ink"
                android:textColorHint="@color/cl_ink_soft"
                android:background="@drawable/bg_edit_text"
                android:padding="@dimen/space_3"
                android:fontFamily="@font/inter_regular"
                android:textSize="@dimen/text_normal"
                android:layout_marginBottom="@dimen/space_3"/>

            <Button
                android:id="@+id/btn_save_email"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/settings_email_save"
                style="@style/ButtonStyle"/>
        </LinearLayout>

        <!-- ═══════════════════════════════════════════════════════════ -->
        <!-- Section: Voice Chat                                         -->
        <!-- ═══════════════════════════════════════════════════════════ -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="VOICE CHAT"
            style="@style/SectionLabelStyle"
            android:textAllCaps="true"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="@dimen/space_5"
            android:layout_marginBottom="@dimen/space_6">

            <!-- API Key -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="DeepInfra API Key"
                android:textColor="@color/cl_ink"
                android:fontFamily="@font/inter_medium"
                android:textSize="@dimen/text_normal"
                android:layout_marginBottom="@dimen/space_2"/>

            <EditText
                android:id="@+id/edit_chat_api_key"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="sk-..."
                android:inputType="textPassword"
                android:textColor="@color/cl_ink"
                android:textColorHint="@color/cl_ink_soft"
                android:background="@drawable/bg_edit_text"
                android:padding="@dimen/space_3"
                android:fontFamily="@font/inter_regular"
                android:textSize="@dimen/text_normal"
                android:layout_marginBottom="@dimen/space_4"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/cl_border"
                android:layout_marginBottom="@dimen/space_4"/>

            <!-- LLM Model -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="LLM-Modell"
                android:textColor="@color/cl_ink"
                android:fontFamily="@font/inter_medium"
                android:textSize="@dimen/text_normal"
                android:layout_marginBottom="@dimen/space_2"/>

            <EditText
                android:id="@+id/edit_chat_model"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="meta-llama/Meta-Llama-3.1-70B-Instruct"
                android:inputType="text"
                android:textColor="@color/cl_ink"
                android:textColorHint="@color/cl_ink_soft"
                android:background="@drawable/bg_edit_text"
                android:padding="@dimen/space_3"
                android:fontFamily="@font/inter_regular"
                android:textSize="@dimen/text_normal"
                android:layout_marginBottom="@dimen/space_4"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/cl_border"
                android:layout_marginBottom="@dimen/space_4"/>

            <!-- TTS Voice (Kokoro — legacy, still in prefs) -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="TTS-Stimme (Kokoro)"
                android:textColor="@color/cl_ink"
                android:fontFamily="@font/inter_medium"
                android:textSize="@dimen/text_normal"
                android:layout_marginBottom="@dimen/space_2"/>

            <Spinner
                android:id="@+id/spinner_chat_tts_voice"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/space_4"/>

            <!-- Offline TTS model (Sherpa-ONNX / Thorsten) -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Offline-Sprachmodell (Thorsten Medium)"
                android:textColor="@color/cl_ink"
                android:fontFamily="@font/inter_medium"
                android:textSize="@dimen/text_normal"
                android:layout_marginBottom="@dimen/space_2"/>

            <TextView
                android:id="@+id/tv_tts_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="@color/cl_ink_soft"
                android:fontFamily="@font/inter_regular"
                android:textSize="@dimen/text_small"
                android:layout_marginBottom="@dimen/space_2"/>

            <Button
                android:id="@+id/btn_tts_download"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Thorsten-Stimme herunterladen"
                android:layout_marginBottom="@dimen/space_4"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/cl_border"
                android:layout_marginBottom="@dimen/space_4"/>

            <!-- Endword -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Endwort (Sende-Signal)"
                android:textColor="@color/cl_ink"
                android:fontFamily="@font/inter_medium"
                android:textSize="@dimen/text_normal"
                android:layout_marginBottom="@dimen/space_2"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Dieses Wort am Ende deiner Frage sendet die Nachricht an die KI."
                android:textColor="@color/cl_ink_soft"
                android:fontFamily="@font/inter_regular"
                android:textSize="@dimen/text_small"
                android:layout_marginBottom="@dimen/space_2"/>

            <EditText
                android:id="@+id/edit_chat_endword"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="over"
                android:inputType="text"
                android:textColor="@color/cl_ink"
                android:textColorHint="@color/cl_ink_soft"
                android:background="@drawable/bg_edit_text"
                android:padding="@dimen/space_3"
                android:fontFamily="@font/inter_regular"
                android:textSize="@dimen/text_normal"
                android:layout_marginBottom="@dimen/space_4"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/cl_border"
                android:layout_marginBottom="@dimen/space_4"/>

            <!-- System Prompt -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="System Prompt"
                android:textColor="@color/cl_ink"
                android:fontFamily="@font/inter_medium"
                android:textSize="@dimen/text_normal"
                android:layout_marginBottom="@dimen/space_2"/>

            <EditText
                android:id="@+id/edit_chat_sysprompt"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Du bist ein pr&#228;ziser Diskussionspartner&#8230;"
                android:inputType="textMultiLine"
                android:minLines="3"
                android:gravity="top|start"
                android:textColor="@color/cl_ink"
                android:textColorHint="@color/cl_ink_soft"
                android:background="@drawable/bg_edit_text"
                android:padding="@dimen/space_3"
                android:fontFamily="@font/inter_regular"
                android:textSize="@dimen/text_normal"
                android:layout_marginBottom="@dimen/space_4"/>

            <!-- Save button -->
            <Button
                android:id="@+id/btn_save_chat_settings"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Chat-Einstellungen speichern"
                style="@style/ButtonStyle"/>

        </LinearLayout>

    </LinearLayout>
</ScrollView>
