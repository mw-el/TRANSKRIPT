<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cl_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/space_5">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="@dimen/space_4"
            android:layout_marginBottom="@dimen/space_5">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="TRANSKR!PT"
                android:textSize="26sp"
                android:fontFamily="@font/poppins_semibold"
                android:textStyle="bold"
                android:textColor="@color/cl_ink"/>

            <ImageButton
                android:id="@+id/btn_menu"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:src="@drawable/ic_menu"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/btn_settings"
                android:padding="10dp"/>
        </LinearLayout>

        <!-- Unified setup card: shown until all 3 steps are complete -->
        <LinearLayout
            android:id="@+id/card_setup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="@dimen/space_5"
            android:layout_marginBottom="@dimen/space_4"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="App einrichten"
                android:textSize="16sp"
                android:fontFamily="@font/poppins_semibold"
                android:textStyle="bold"
                android:textColor="@color/cl_ink"
                android:layout_marginBottom="@dimen/space_4"/>

            <!-- Step 1: Microphone -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="@dimen/space_3">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Mikrofon"
                        android:textSize="14sp"
                        android:fontFamily="@font/poppins_semibold"
                        android:textStyle="bold"
                        android:textColor="@color/cl_ink"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Zum Aufnehmen von Sprache"
                        android:textSize="12sp"
                        android:fontFamily="@font/inter_regular"
                        android:textColor="@color/cl_ink_soft"/>
                </LinearLayout>

                <Button
                    android:id="@+id/btn_mic_grant"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="Freigeben"
                    android:textSize="13sp"
                    android:textColor="@color/white"
                    android:paddingStart="@dimen/space_4"
                    android:paddingEnd="@dimen/space_4"
                    android:background="@drawable/bg_button_primary"
                    android:backgroundTint="@color/cl_accent2"
                    android:stateListAnimator="@null"
                    />

                <TextView
                    android:id="@+id/txt_mic_done"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✓"
                    android:textSize="20sp"
                    android:textColor="@color/cl_green"
                    android:textStyle="bold"
                    android:visibility="gone"/>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/cl_border"
                android:layout_marginBottom="@dimen/space_3"/>

            <!-- Step 2: Keyboard -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="@dimen/space_3">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tastatur"
                        android:textSize="14sp"
                        android:fontFamily="@font/poppins_semibold"
                        android:textStyle="bold"
                        android:textColor="@color/cl_ink"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Als alternative Eingabemethode"
                        android:textSize="12sp"
                        android:fontFamily="@font/inter_regular"
                        android:textColor="@color/cl_ink_soft"/>
                </LinearLayout>

                <Button
                    android:id="@+id/btn_ime_setup"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="Einrichten"
                    android:textSize="13sp"
                    android:textColor="@color/white"
                    android:paddingStart="@dimen/space_4"
                    android:paddingEnd="@dimen/space_4"
                    android:background="@drawable/bg_button_primary"
                    android:backgroundTint="@color/cl_accent2"
                    android:stateListAnimator="@null"
                    />

                <TextView
                    android:id="@+id/txt_ime_done"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✓"
                    android:textSize="20sp"
                    android:textColor="@color/cl_green"
                    android:textStyle="bold"
                    android:visibility="gone"/>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/cl_border"
                android:layout_marginBottom="@dimen/space_3"/>

            <!-- Step 3: Storage folder -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Speicherort"
                        android:textSize="14sp"
                        android:fontFamily="@font/poppins_semibold"
                        android:textStyle="bold"
                        android:textColor="@color/cl_ink"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="z.B. Dokumente → Transkript"
                        android:textSize="12sp"
                        android:fontFamily="@font/inter_regular"
                        android:textColor="@color/cl_ink_soft"/>
                </LinearLayout>

                <Button
                    android:id="@+id/btn_folder_setup"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="Wählen"
                    android:textSize="13sp"
                    android:textColor="@color/white"
                    android:paddingStart="@dimen/space_4"
                    android:paddingEnd="@dimen/space_4"
                    android:background="@drawable/bg_button_primary"
                    android:backgroundTint="@color/cl_accent2"
                    android:stateListAnimator="@null"
                    />

                <TextView
                    android:id="@+id/txt_folder_done"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✓"
                    android:textSize="20sp"
                    android:textColor="@color/cl_green"
                    android:textStyle="bold"
                    android:visibility="gone"/>
            </LinearLayout>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="@dimen/space_5"
            android:layout_marginBottom="@dimen/space_4">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/section_dictate"
                android:textSize="18sp"
                android:fontFamily="@font/poppins_semibold"
                android:textStyle="bold"
                android:textColor="@color/cl_ink"
                android:layout_marginBottom="@dimen/space_3"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btn_dictate"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/btn_dictate"
                    style="@style/ButtonStyle"
                    android:layout_marginEnd="@dimen/space_2"/>

                <Button
                    android:id="@+id/btn_recordings_manager"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/btn_recordings_manager"
                    style="@style/SecondaryButtonStyle"/>
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="@dimen/space_5"
            android:layout_marginBottom="@dimen/space_4">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Audiodatei transkribieren"
                android:textSize="18sp"
                android:fontFamily="@font/poppins_semibold"
                android:textStyle="bold"
                android:textColor="@color/cl_ink"
                android:layout_marginBottom="@dimen/space_2"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Audiodatei vom Gerät wählen und offline transkribieren."
                android:fontFamily="@font/inter_regular"
                android:textColor="@color/cl_ink_soft"
                android:textSize="14sp"
                android:layout_marginBottom="@dimen/space_4"/>

            <Button
                android:id="@+id/btn_transcribe_file"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Audiodatei wählen"
                style="@style/ButtonStyle"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="@dimen/space_5"
            android:layout_marginBottom="@dimen/space_5">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/section_subs"
                android:textSize="18sp"
                android:fontFamily="@font/poppins_semibold"
                android:textStyle="bold"
                android:textColor="@color/cl_ink"
                android:layout_marginBottom="@dimen/space_2"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/desc_subs"
                android:fontFamily="@font/inter_regular"
                android:textColor="@color/cl_ink_soft"
                android:textSize="14sp"
                android:layout_marginBottom="@dimen/space_4"/>

            <Button
                android:id="@+id/btn_subs_start"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/btn_subs_start"
                style="@style/ButtonStyle"
                android:backgroundTint="@color/cl_green"/>
        </LinearLayout>

        <TextView
            android:id="@+id/text_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Status: Prüfe…"
            android:gravity="center"
            android:fontFamily="@font/inter_regular"
            android:textColor="@color/cl_ink_soft"
            android:textSize="13sp"
            android:layout_marginBottom="@dimen/space_4"/>

    </LinearLayout>
</ScrollView>
