<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cl_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/space_5">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="@dimen/space_4"
            android:layout_marginBottom="@dimen/space_5">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="TRANSKR!PT"
                android:textSize="26sp"
                android:fontFamily="@font/poppins_semibold"
                android:textStyle="bold"
                android:textColor="@color/cl_ink"/>

            <ImageButton
                android:id="@+id/btn_settings"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:src="@drawable/ic_settings"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/btn_settings"
                android:padding="10dp"/>
        </LinearLayout>

        <!-- Permissions card (shown only if mic permission missing) -->
        <LinearLayout
            android:id="@+id/card_permissions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="@dimen/space_5"
            android:layout_marginBottom="@dimen/space_4"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/perm_mic_title"
                android:textSize="16sp"
                android:fontFamily="@font/poppins_semibold"
                android:textStyle="bold"
                android:textColor="@color/cl_red"
                android:layout_marginBottom="@dimen/space_2"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/perm_mic_desc"
                android:fontFamily="@font/inter_regular"
                android:textColor="@color/cl_ink_soft"
                android:textSize="14sp"
                android:layout_marginBottom="@dimen/space_4"/>

            <Button
                android:id="@+id/btn_grant_perms"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/btn_grant"
                style="@style/ButtonStyle"
                android:backgroundTint="@color/cl_red"/>
        </LinearLayout>

        <!-- IME: single button, no header -->
        <Button
            android:id="@+id/btn_ime_settings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="1. Tastatureinstellungen öffnen"
            style="@style/SecondaryButtonStyle"
            android:layout_marginBottom="@dimen/space_4"/>

        <!-- Diktieren card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="@dimen/space_5"
            android:layout_marginBottom="@dimen/space_4">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/section_dictate"
                android:textSize="18sp"
                android:fontFamily="@font/poppins_semibold"
                android:textStyle="bold"
                android:textColor="@color/cl_ink"
                android:layout_marginBottom="@dimen/space_3"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btn_dictate"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/btn_dictate"
                    style="@style/ButtonStyle"
                    android:layout_marginEnd="@dimen/space_2"/>

                <Button
                    android:id="@+id/btn_recordings_manager"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/btn_recordings_manager"
                    style="@style/SecondaryButtonStyle"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Audiodatei transkribieren card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="@dimen/space_5"
            android:layout_marginBottom="@dimen/space_4">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Audiodatei transkribieren"
                android:textSize="18sp"
                android:fontFamily="@font/poppins_semibold"
                android:textStyle="bold"
                android:textColor="@color/cl_ink"
                android:layout_marginBottom="@dimen/space_2"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Audiodatei vom Gerät wählen und offline transkribieren."
                android:fontFamily="@font/inter_regular"
                android:textColor="@color/cl_ink_soft"
                android:textSize="14sp"
                android:layout_marginBottom="@dimen/space_4"/>

            <Button
                android:id="@+id/btn_transcribe_file"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Audiodatei wählen"
                style="@style/ButtonStyle"/>
        </LinearLayout>

        <!-- Live-Untertitel card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="@dimen/space_5"
            android:layout_marginBottom="@dimen/space_5">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/section_subs"
                android:textSize="18sp"
                android:fontFamily="@font/poppins_semibold"
                android:textStyle="bold"
                android:textColor="@color/cl_ink"
                android:layout_marginBottom="@dimen/space_2"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/desc_subs"
                android:fontFamily="@font/inter_regular"
                android:textColor="@color/cl_ink_soft"
                android:textSize="14sp"
                android:layout_marginBottom="@dimen/space_4"/>

            <Button
                android:id="@+id/btn_subs_start"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/btn_subs_start"
                style="@style/ButtonStyle"
                android:backgroundTint="@color/cl_green"/>
        </LinearLayout>

        <!-- Status -->
        <TextView
            android:id="@+id/text_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Status: Prüfe…"
            android:gravity="center"
            android:fontFamily="@font/inter_regular"
            android:textColor="@color/cl_ink_soft"
            android:textSize="13sp"
            android:layout_marginBottom="@dimen/space_4"/>

    </LinearLayout>
</ScrollView>
