<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:fitsSystemWindows="true"
    android:background="@color/cl_bg">

    <!-- Toolbar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:background="@color/cl_bg">

        <ImageButton
            android:id="@+id/btn_chat_close"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="Schlie\u00dfen"
            android:tint="@color/cl_ink" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Voice Chat"
            android:textSize="18sp"
            android:fontFamily="@font/poppins_semibold"
            android:textStyle="bold"
            android:textColor="@color/cl_ink"
            android:paddingStart="8dp" />

        <ImageButton
            android:id="@+id/btn_chat_attach"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_menu_add"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="Datei anh\u00e4ngen"
            android:tint="@color/cl_ink" />

        <!-- Language selector chip -->
        <TextView
            android:id="@+id/btn_chat_lang"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:gravity="center"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:text="DE"
            android:textSize="13sp"
            android:textColor="@color/cl_ink"
            android:fontFamily="@font/inter_medium"
            android:background="@drawable/bg_button_secondary"
            android:layout_marginEnd="4dp" />

        <ImageButton
            android:id="@+id/btn_chat_share"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_share"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="Transkript teilen"
            android:tint="@color/cl_ink" />

        <ImageButton
            android:id="@+id/btn_chat_settings"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_settings"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="Einstellungen"
            android:tint="@color/cl_ink" />
    </LinearLayout>

    <!-- Chat messages area -->
    <ScrollView
        android:id="@+id/scroll_chat"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp">

        <LinearLayout
            android:id="@+id/chat_messages"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />
    </ScrollView>

    <!-- Status bar -->
    <TextView
        android:id="@+id/tv_chat_status"
        android:layout_width="match_parent"
        android:layout_height="32dp"
        android:gravity="center"
        android:textSize="13sp"
        android:fontFamily="@font/inter_regular"
        android:textColor="@color/cl_ink_soft"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:text="Bereit" />

    <!-- Mic button row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:paddingTop="8dp"
        android:paddingBottom="24dp"
        android:background="@color/cl_bg">

        <ImageButton
            android:id="@+id/btn_chat_mic"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:src="@drawable/ic_mic"
            android:background="@drawable/bg_round_button"
            android:contentDescription="Sprechen / Stopp" />
    </LinearLayout>

</LinearLayout>
