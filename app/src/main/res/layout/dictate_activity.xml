<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/cl_bg"
    android:fitsSystemWindows="true">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="@dimen/space_5"
        android:paddingEnd="@dimen/space_5"
        android:layout_marginTop="@dimen/space_4"
        android:layout_marginBottom="@dimen/space_2">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/dictate_title"
            android:textSize="20sp"
            android:fontFamily="@font/poppins_semibold"
            android:textStyle="bold"
            android:textColor="@color/cl_ink"/>

        <ImageButton
            android:id="@+id/btn_close"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:tint="@color/cl_ink_soft"
            android:contentDescription="@string/btn_close"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingStart="@dimen/space_5"
        android:paddingEnd="@dimen/space_5">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/dictate_subtitle"
            android:textColor="@color/cl_ink_soft"
            android:fontFamily="@font/inter_regular"
            android:textSize="14sp"
            android:layout_marginBottom="@dimen/space_5"/>

        <!-- Spacer to push button to center vertically -->
        <View
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"/>

        <!-- Waveform view (INVISIBLE at rest, VISIBLE during recording) -->
        <dev.transcribe.WaveformView
            android:id="@+id/waveform_view"
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:visibility="invisible"
            android:layout_marginBottom="@dimen/space_4"/>

        <!-- Round record button centered -->
        <ImageButton
            android:id="@+id/btn_record"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:layout_gravity="center_horizontal"
            android:src="@drawable/ic_mic"
            android:tint="@color/white"
            android:scaleType="centerInside"
            android:padding="24dp"
            android:background="@drawable/bg_round_button"
            android:contentDescription="@string/dictate_btn_start"
            android:stateListAnimator="@null"
            android:layout_marginBottom="@dimen/space_4"/>

        <!-- Timer -->
        <TextView
            android:id="@+id/tv_timer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:text="00:00"
            android:textColor="@color/cl_ink"
            android:textSize="36sp"
            android:fontFamily="monospace"
            android:layout_marginBottom="@dimen/space_2"/>

        <!-- Status -->
        <TextView
            android:id="@+id/tv_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:text="@string/dictate_status_idle"
            android:textColor="@color/cl_ink_soft"
            android:fontFamily="@font/inter_regular"
            android:textSize="14sp"
            android:layout_marginBottom="@dimen/space_2"/>

        <!-- Hint shown during recording -->
        <TextView
            android:id="@+id/tv_hint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:gravity="center"
            android:text="Zum Stoppen und Transkribieren einfach Stopp-Taste klicken"
            android:textColor="@color/cl_ink_soft"
            android:fontFamily="@font/inter_regular"
            android:textSize="13sp"
            android:visibility="gone"/>

        <!-- Lock section: shown during recording to protect against accidental touches -->
        <LinearLayout
            android:id="@+id/lock_section"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:layout_marginTop="@dimen/space_5"
            android:visibility="gone">

            <ImageButton
                android:id="@+id/btn_screen_lock"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:src="@drawable/ic_lock_open"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:padding="12dp"
                android:contentDescription="Bildschirm sperren"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Aufnahme sichern"
                android:textColor="@color/cl_ink_soft"
                android:fontFamily="@font/inter_regular"
                android:textSize="12sp"
                android:layout_marginTop="@dimen/space_1"/>

        </LinearLayout>

        <!-- Spacer bottom -->
        <View
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"/>

    </LinearLayout>

</LinearLayout>
