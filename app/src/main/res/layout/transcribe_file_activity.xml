<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#111827"
    android:fitsSystemWindows="true"
    android:padding="24dp">

    <ImageButton
        android:id="@+id/btn_close"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:src="@android:drawable/ic_menu_close_clear_cancel"
        android:background="#1F2937"
        android:tint="#9CA3AF"
        android:contentDescription="Schließen"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingTop="48dp"
        android:paddingBottom="16dp">

        <!-- Progress area -->
        <LinearLayout
            android:id="@+id/progress_area"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="32dp">

            <ProgressBar
                android:id="@+id/progress_bar"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:layout_marginBottom="16dp"
                android:indeterminateTint="#3B82F6"/>

            <TextView
                android:id="@+id/txt_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Lade…"
                android:textColor="#9CA3AF"
                android:textSize="15sp" />
        </LinearLayout>

        <!-- Result area -->
        <ScrollView
            android:id="@+id/result_area"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:visibility="gone">

            <TextView
                android:id="@+id/txt_result"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#F3F4F6"
                android:textSize="16sp"
                android:lineSpacingMultiplier="1.5"
                android:padding="8dp"
                android:textIsSelectable="true" />
        </ScrollView>

        <!-- Action buttons: Copy | Save | Share | Mail -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="8dp">

            <Button
                android:id="@+id/btn_copy"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="3dp"
                android:text="@string/transcript_copy"
                android:visibility="gone"
                android:backgroundTint="#3B82F6"
                android:textColor="#FFFFFF"
                android:textSize="13sp"/>

            <Button
                android:id="@+id/btn_save"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="3dp"
                android:layout_marginEnd="3dp"
                android:text="@string/transcript_save"
                android:visibility="gone"
                android:backgroundTint="#10B981"
                android:textColor="#FFFFFF"
                android:textSize="13sp"/>

            <Button
                android:id="@+id/btn_share"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="3dp"
                android:layout_marginEnd="3dp"
                android:text="@string/transcript_share"
                android:visibility="gone"
                android:backgroundTint="#6366F1"
                android:textColor="#FFFFFF"
                android:textSize="13sp"/>

            <Button
                android:id="@+id/btn_mail"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="3dp"
                android:text="@string/transcript_mail"
                android:visibility="gone"
                android:backgroundTint="#F59E0B"
                android:textColor="#FFFFFF"
                android:textSize="13sp"/>

        </LinearLayout>

    </LinearLayout>
</LinearLayout>
