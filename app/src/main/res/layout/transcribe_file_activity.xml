<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/cl_bg"
    android:fitsSystemWindows="true"
    android:padding="@dimen/space_5">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="@dimen/space_4"
        android:layout_marginBottom="@dimen/space_4">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Transkription"
            android:textSize="20sp"
            android:fontFamily="@font/poppins_semibold"
            android:textStyle="bold"
            android:textColor="@color/cl_ink"/>

        <ImageButton
            android:id="@+id/btn_close"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:tint="@color/cl_ink_soft"
            android:contentDescription="Schließen"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Progress area -->
        <LinearLayout
            android:id="@+id/progress_area"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="@dimen/space_6"
            android:layout_marginTop="@dimen/space_6">

            <!-- Status text (Modell laden / Dekodiere / Transkribiere) -->
            <TextView
                android:id="@+id/txt_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/status_loading_model"
                android:textColor="@color/cl_ink"
                android:fontFamily="@font/poppins_semibold"
                android:textSize="17sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginBottom="@dimen/space_4"/>

            <!-- Detail text (shown during load/decode, hidden during transcription) -->
            <TextView
                android:id="@+id/txt_detail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="@color/cl_ink_soft"
                android:fontFamily="@font/inter_regular"
                android:textSize="13sp"
                android:gravity="center"
                android:layout_marginBottom="@dimen/space_4"
                android:textIsSelectable="true"/>

            <!-- Three pulsing dots — visible only during STAGE_TRANSCRIBE -->
            <LinearLayout
                android:id="@+id/dots_container"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:visibility="visible">

                <View
                    android:id="@+id/dot_1"
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/dot_indicator"
                    android:alpha="0.2"/>

                <View
                    android:id="@+id/dot_2"
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/dot_indicator"
                    android:alpha="0.2"/>

                <View
                    android:id="@+id/dot_3"
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:background="@drawable/dot_indicator"
                    android:alpha="0.2"/>

            </LinearLayout>

        </LinearLayout>

        <!-- Result area -->
        <ScrollView
            android:id="@+id/result_area"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:visibility="gone">

            <TextView
                android:id="@+id/txt_result"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/cl_ink"
                android:fontFamily="@font/inter_regular"
                android:textSize="16sp"
                android:lineSpacingMultiplier="1.6"
                android:padding="@dimen/space_2"
                android:textIsSelectable="true"/>
        </ScrollView>

        <!-- Saved path info -->
        <TextView
            android:id="@+id/txt_saved_path"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="@color/cl_green"
            android:fontFamily="@font/inter_regular"
            android:textSize="13sp"
            android:padding="@dimen/space_2"
            android:layout_marginTop="@dimen/space_2"
            android:textIsSelectable="true"
            android:visibility="gone"/>

        <!-- Action buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="@dimen/space_3"
            android:layout_marginBottom="@dimen/space_3">

            <Button
                android:id="@+id/btn_copy"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="3dp"
                android:text="@string/transcript_copy"
                android:visibility="gone"
                style="@style/ButtonStyle"
                android:textSize="12sp"/>

            <Button
                android:id="@+id/btn_save"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="3dp"
                android:layout_marginEnd="3dp"
                android:text="@string/transcript_save"
                android:visibility="gone"
                style="@style/ButtonStyle"
                android:backgroundTint="@color/cl_green"
                android:textSize="12sp"/>

            <Button
                android:id="@+id/btn_open"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="3dp"
                android:layout_marginEnd="3dp"
                android:text="@string/transcript_open"
                android:visibility="gone"
                style="@style/ButtonStyle"
                android:backgroundTint="@color/cl_accent2"
                android:textSize="12sp"/>

            <Button
                android:id="@+id/btn_share"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="3dp"
                android:text="@string/transcript_share"
                android:visibility="gone"
                style="@style/SecondaryButtonStyle"
                android:textSize="12sp"/>

        </LinearLayout>

    </LinearLayout>
</LinearLayout>
