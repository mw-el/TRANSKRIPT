<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cl_bg"
    android:fitsSystemWindows="true">

    <!-- Main content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="@dimen/space_5"
            android:paddingEnd="@dimen/space_5"
            android:layout_marginTop="@dimen/space_4"
            android:layout_marginBottom="@dimen/space_4">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Transkription"
                android:textSize="@dimen/text_heading"
                android:fontFamily="@font/poppins_semibold"
                android:textStyle="bold"
                android:textColor="@color/cl_ink"/>

            <ImageButton
                android:id="@+id/btn_close"
                android:layout_width="@dimen/btn_icon_size"
                android:layout_height="@dimen/btn_icon_size"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:tint="@color/cl_ink_soft"
                android:contentDescription="Schließen"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:paddingStart="@dimen/space_5"
            android:paddingEnd="@dimen/space_5">

            <!-- Result area -->
            <ScrollView
                android:id="@+id/result_area"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1">

                <EditText
                    android:id="@+id/txt_result"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/cl_ink"
                    android:fontFamily="@font/inter_regular"
                    android:textSize="@dimen/text_large"
                    android:lineSpacingMultiplier="1.6"
                    android:padding="@dimen/space_2"
                    android:inputType="textMultiLine"
                    android:focusable="true"
                    android:focusableInTouchMode="true"
                    android:background="@null"
                    android:overScrollMode="never"/>
            </ScrollView>

            <!-- Saved path info -->
            <TextView
                android:id="@+id/txt_saved_path"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="@color/cl_green"
                android:fontFamily="@font/inter_regular"
                android:textSize="@dimen/text_small"
                android:padding="@dimen/space_2"
                android:layout_marginTop="@dimen/space_2"
                android:textIsSelectable="true"
                android:visibility="gone"/>

            <!-- Action buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginTop="@dimen/space_3"
                android:layout_marginBottom="@dimen/space_3">

                <ImageButton
                    android:id="@+id/btn_copy"
                    android:layout_width="@dimen/btn_action_size"
                    android:layout_height="@dimen/btn_action_size"
                    android:layout_marginEnd="@dimen/space_3"
                    android:src="@drawable/ic_copy"
                    android:background="@drawable/bg_button_primary"
                    android:padding="14dp"
                    android:contentDescription="@string/transcript_copy"
                    android:visibility="gone"/>

                <ImageButton
                    android:id="@+id/btn_save"
                    android:layout_width="@dimen/btn_action_size"
                    android:layout_height="@dimen/btn_action_size"
                    android:layout_marginEnd="@dimen/space_3"
                    android:src="@drawable/ic_save"
                    android:background="@drawable/bg_button_primary"
                    android:backgroundTint="@color/cl_accent2"
                    android:padding="14dp"
                    android:contentDescription="Speichern"
                    android:visibility="gone"/>

                <ImageButton
                    android:id="@+id/btn_share"
                    android:layout_width="@dimen/btn_action_size"
                    android:layout_height="@dimen/btn_action_size"
                    android:src="@drawable/ic_share"
                    android:background="@drawable/bg_button_primary"
                    android:backgroundTint="@color/cl_green"
                    android:padding="14dp"
                    android:contentDescription="@string/transcript_share"
                    android:visibility="gone"/>

            </LinearLayout>

        </LinearLayout>
    </LinearLayout>

    <!-- Floating status pill — draggable, centered initially -->
    <LinearLayout
        android:id="@+id/pill_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/bg_pill_status"
        android:paddingStart="14dp"
        android:paddingEnd="18dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp"
        android:elevation="8dp"
        android:visibility="gone">

        <ProgressBar
            android:id="@+id/pill_spinner"
            style="?android:attr/progressBarStyleSmall"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:indeterminate="true"
            android:indeterminateTint="@color/cl_accent"
            android:layout_marginEnd="10dp"/>

        <TextView
            android:id="@+id/pill_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/cl_ink"
            android:fontFamily="@font/inter_regular"
            android:textSize="@dimen/text_button"
            android:maxWidth="240dp"
            android:singleLine="true"/>

    </LinearLayout>

</FrameLayout>
